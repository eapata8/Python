import importlib
import importlib.metadata
import importlib.util
import unittest

PACKAGE_NAME = "aidRepo"

EXPECTED_TOP_LEVEL = {
    "common",
    "evaluation",
    "inference",
    "main",
    "ml_pipeline",
    "preprocessing",
    "training",
}


class TestPackaging(unittest.TestCase):

    @classmethod
    def setUpClass(cls):
        cls.dist = importlib.metadata.distribution(PACKAGE_NAME)

    def test_package_is_installed(self):
        self.assertIsNotNone(self.dist)
        self.assertIsNotNone(importlib.util.find_spec(PACKAGE_NAME))

    def test_top_level_entities(self):
        top_level = set(
            self.dist.read_text("top_level.txt").splitlines()
        )

        self.assertEqual(top_level, EXPECTED_TOP_LEVEL)

        for module in EXPECTED_TOP_LEVEL:
            with self.subTest(module=module):
                self.assertIsNotNone(importlib.import_module(module))

    def test_distribution_contains_only_sources(self):
        files = {str(f) for f in self.dist.files}

        self.assertIn("main.py", files)

        for module in EXPECTED_TOP_LEVEL - {"main"}:
            self.assertIn(f"{module}/__init__.py", files)

        for file in files:
            self.assertFalse(
                file.startswith("tests/"),
                f"Unexpected test file in package: {file}",
            )


if __name__ == "__main__":
    unittest.main(verbosity=2)



import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
SRC = ROOT / "src_example"


def run(cmd, cwd):
    print("\n$", " ".join(map(str, cmd)))
    subprocess.run(cmd, cwd=cwd)


def bad_toml():
    (SRC / "pyproject.toml").write_text("""
[build-system]
requires = ["setuptools"]
build-backend = "setuptools.build_meta"

[project]
name = "calculator"
version = "2026.0.0"

[tool.setuptools]
packages = []
""")


def good_toml():
    (SRC / "pyproject.toml").write_text("""
[build-system]
requires = ["setuptools"]
build-backend = "setuptools.build_meta"

[project]
name = "calculator"
version = "2026.0.0"

[tool.setuptools.packages.find]
where = ["src"]
""")


bad_toml()

print("\nLocal test without install")

run(
    [sys.executable, "-m", "unittest", "discover", "-s", "tests"],
    SRC,
)

with tempfile.TemporaryDirectory() as tmp:

    venv = Path(tmp) / "venv"
    outside = Path(tmp) / "outside"

    outside.mkdir()

    run(
        [sys.executable, "-m", "venv", str(venv)],
        SRC,
    )

    python = venv / "bin" / "python"

    print("\nInstall broken package")

    run(
        [str(python), "-m", "pip", "install", "."],
        SRC,
    )

    print("\nImport from root")

    run(
        [
            str(python),
            "-c",
            "from calculator.operations import addition; print(addition(2,3))",
        ],
        SRC,
    )

    print("\nImport from outside")

    run(
        [
            str(python),
            "-c",
            "from calculator.operations import addition; print(addition(2,3))",
        ],
        outside,
    )

    good_toml()

    print("\nReinstall fixed package")

    run(
        [str(python), "-m", "pip", "install", "--force-reinstall", "."],
        SRC,
    )

    print("\nImport from root again")

    run(
        [
            str(python),
            "-c",
            "from calculator.operations import addition; print(addition(2,3))",
        ],
        SRC,
    )

    print("\nImport from outside again")

    run(
        [
            str(python),
            "-c",
            "from calculator.operations import addition; print(addition(2,3))",
        ],
        outside,
    )
